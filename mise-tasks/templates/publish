#!/usr/bin/env bash
#MISE description="Publish template packages to their respective registries"
set -euo pipefail
cd "${MISE_PROJECT_ROOT:-$PWD}"
source "${MISE_PROJECT_ROOT:-$PWD}/mise-tasks/utils"

TMP_DIR=".tmp/publish-templates"
rm -rf "$TMP_DIR"
mkdir -p "$TMP_DIR"

# Capture GH_REPO from base repo before changing directories
# GITHUB_REPOSITORY is set in CI; fall back to git remote for local runs
BASE_GH_REPO="${GITHUB_REPOSITORY:-$(git remote get-url origin 2>/dev/null \
    | sed 's|.*github.com[:/]\([^/]*/[^/.]*\).*|\1|')}"

log_info "Publishing template packages for mise-lib-template v$VERSION..."

# --- mise-uv-template → PyPI ---
log_info "Scaffolding mise-uv-template..."
mkdir -p "$TMP_DIR/mise-uv-template"
mise run scaffold -- \
    --src . --dest "$TMP_DIR/mise-uv-template" \
    --project mise-uv-template --template uv --non-interactive

sed_inplace "s/^version = .*/version = \"$VERSION\"/" \
    "$TMP_DIR/mise-uv-template/pyproject.toml"

log_info "Publishing mise-uv-template $VERSION to PyPI..."
(cd "$TMP_DIR/mise-uv-template" && mise run publish)
log_success "mise-uv-template $VERSION published to PyPI"

# --- mise-zig-template → GitHub Releases (attach to existing release) ---
# The mise-lib-template GitHub Release at v$VERSION is created by semantic-release
# before publish-templates runs. GH_REPO ensures gh targets the right repo from .tmp/.
log_info "Scaffolding mise-zig-template..."
mkdir -p "$TMP_DIR/mise-zig-template"
mise run scaffold -- \
    --src . --dest "$TMP_DIR/mise-zig-template" \
    --project mise-zig-template --template zig --non-interactive

echo "$VERSION" > "$TMP_DIR/mise-zig-template/version.txt"
sed_inplace "s/^\\( *\\)\\.version = \".*\"/\\1.version = \"$VERSION\"/" \
    "$TMP_DIR/mise-zig-template/build.zig.zon"

log_info "Uploading mise-zig-template $VERSION binaries to GitHub release v$VERSION..."
(cd "$TMP_DIR/mise-zig-template" && GH_REPO="$BASE_GH_REPO" mise run publish)
log_success "mise-zig-template $VERSION assets attached to GitHub release v$VERSION"

# --- mise-go-template → GitHub Releases (attach to existing release) ---
# Go has no manifest version field; only version.txt is bumped. The mise-lib-template
# GitHub Release at v$VERSION already exists (created by semantic-release before this runs).
log_info "Scaffolding mise-go-template..."
mkdir -p "$TMP_DIR/mise-go-template"
mise run scaffold -- \
    --src . --dest "$TMP_DIR/mise-go-template" \
    --project mise-go-template --template go --non-interactive

echo "$VERSION" > "$TMP_DIR/mise-go-template/version.txt"

log_info "Uploading mise-go-template $VERSION binaries to GitHub release v$VERSION..."
(cd "$TMP_DIR/mise-go-template" && GH_REPO="$BASE_GH_REPO" mise run publish)
log_success "mise-go-template $VERSION assets attached to GitHub release v$VERSION"

# --- mise-rust-template → GitHub Releases (attach to existing release) ---
# Same release as zig; GH_REPO ensures gh targets the base repo from .tmp/.
log_info "Scaffolding mise-rust-template..."
mkdir -p "$TMP_DIR/mise-rust-template"
mise run scaffold -- \
    --src . --dest "$TMP_DIR/mise-rust-template" \
    --project mise-rust-template --template rust --non-interactive

echo "$VERSION" > "$TMP_DIR/mise-rust-template/version.txt"
sed_inplace "s/^version = \".*\"/version = \"$VERSION\"/" \
    "$TMP_DIR/mise-rust-template/Cargo.toml"

log_info "Uploading mise-rust-template $VERSION binaries to GitHub release v$VERSION..."
(cd "$TMP_DIR/mise-rust-template" && GH_REPO="$BASE_GH_REPO" mise run publish)
log_success "mise-rust-template $VERSION assets attached to GitHub release v$VERSION"

# --- mise-odin-template → GitHub Releases (attach to existing release) ---
# Odin has no manifest — only version.txt needs the release version (simpler than zig).
log_info "Scaffolding mise-odin-template..."
mkdir -p "$TMP_DIR/mise-odin-template"
mise run scaffold -- \
    --src . --dest "$TMP_DIR/mise-odin-template" \
    --project mise-odin-template --template odin --non-interactive

echo "$VERSION" > "$TMP_DIR/mise-odin-template/version.txt"

log_info "Uploading mise-odin-template $VERSION binaries to GitHub release v$VERSION..."
(cd "$TMP_DIR/mise-odin-template" && GH_REPO="$BASE_GH_REPO" mise run publish)
log_success "mise-odin-template $VERSION assets attached to GitHub release v$VERSION"

# --- mise-pnpm-template → npm ---
log_info "Scaffolding mise-pnpm-template..."
mkdir -p "$TMP_DIR/mise-pnpm-template"
mise run scaffold -- \
    --src . --dest "$TMP_DIR/mise-pnpm-template" \
    --project mise-pnpm-template --template pnpm --non-interactive

node -e "
const fs = require('fs');
const pkg = JSON.parse(fs.readFileSync('$TMP_DIR/mise-pnpm-template/package.json', 'utf8'));
pkg.version = '$VERSION';
fs.writeFileSync('$TMP_DIR/mise-pnpm-template/package.json', JSON.stringify(pkg, null, 2) + '\n');
"

log_info "Publishing mise-pnpm-template $VERSION to npm..."
# pnpm (10+) only honors auth from a user-level ~/.npmrc, not a project .npmrc.
[ -n "${NPM_TOKEN:-}" ] || { log_error "NPM_TOKEN is empty"; exit 1; }
printf '//registry.npmjs.org/:_authToken=%s\n' "${NPM_TOKEN}" > "$HOME/.npmrc"
# A project-level .npmrc shadows the user ~/.npmrc, so remove the scaffolded one.
rm -f "$TMP_DIR/mise-pnpm-template/.npmrc"
(cd "$TMP_DIR/mise-pnpm-template" && mise run install && mise run publish)
log_success "mise-pnpm-template $VERSION published to npm"

rm -rf "$TMP_DIR"
log_success "All template packages published"
