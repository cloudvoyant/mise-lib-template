#!/usr/bin/env bash
#MISE description="Publish RC package to PyPI as a pre-release for validation"
set -euo pipefail
source "$(dirname "$0")/utils"

# PEP 440 requires the rc suffix to be a number (PyPI also rejects +local segments),
# so use the monotonic CI run number. pip/uv ignore pre-releases by default, so an
# rcN release on PyPI does not affect normal installs.
RC_NUM="${GITHUB_RUN_NUMBER:-0}"
# Re-runs reuse GITHUB_RUN_NUMBER but bump GITHUB_RUN_ATTEMPT; fold it in so a re-run
# mints a fresh version instead of colliding with the immutable one already on PyPI.
[ "${GITHUB_RUN_ATTEMPT:-1}" != "1" ] && RC_NUM="${RC_NUM}.post${GITHUB_RUN_ATTEMPT}"
RC_VERSION="${VERSION}rc${RC_NUM}"   # PEP 440: 2.2.0rc42 (or 2.2.0rc42.post2)

log_info "Setting RC version $RC_VERSION in pyproject.toml..."
sed_inplace "s/^version = .*/version = \"$RC_VERSION\"/" pyproject.toml

log_info "Publishing $PROJECT $RC_VERSION to PyPI (pre-release)..."
mise run publish

log_success "Published $PROJECT $RC_VERSION to PyPI"
